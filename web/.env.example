# URL to the Express API (no trailing slash)
# In development this is the default below.
# In production, set it to your deployed API URL.
NEXT_PUBLIC_API_BASE="http://localhost:4000/api"

# Stripe publishable key — safe to expose in the browser
# pk_live_... for production, pk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
