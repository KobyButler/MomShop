generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  shops       Shop[]
  createdAt   DateTime  @default(now())
}

model Product {
  id               String      @id @default(cuid())
  name             String
  sku              String      @unique
  vendor           String      @default("OTHER")
  vendorIdentifier String?
  brand            String?
  description      String?
  priceCents       Int
  imagesJson       String?
  sizesJson        String?   // JSON array of strings, e.g. ["S","M","L","XL","2XL"]
  colorsJson       String?   // JSON array of strings, e.g. ["Black","White","Navy"]
  collectionId     String
  collection       Collection  @relation(fields: [collectionId], references: [id])
  orderItems       OrderItem[]
  createdAt        DateTime    @default(now())
}

model Shop {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id])
  active       Boolean    @default(true)
  expiresAt    DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  orders       Order[]
  checkouts    Checkout[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id                  String               @id @default(cuid())
  shopId              String?
  shop                Shop?                @relation(fields: [shopId], references: [id])
  customerId          String?
  customer            Customer?            @relation(fields: [customerId], references: [id])
  status              String               @default("UNFULFILLED") // UNFULFILLED|FULFILLED|CANCELLED|DRAFT
  customerName        String
  customerEmail       String
  shipAddress1        String
  shipAddress2        String?
  shipCity            String
  shipState           String
  shipZip             String
  residential         Boolean              @default(true)
  totalCents          Int                  @default(0)
  createdAt           DateTime             @default(now())
  items               OrderItem[]
  vendorOrders        VendorOrder[]
  discountCodeId      String?
  discountCode        DiscountCode?        @relation(fields: [discountCodeId], references: [id])
  financeTransactions FinanceTransaction[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  size       String?
  color      String?
  quantity   Int
  priceCents Int
}

model DiscountCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String // PERCENT|AMOUNT
  value     Int
  active    Boolean   @default(true)
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int       @default(0)
  createdAt DateTime  @default(now())
  orders    Order[]
}

model VendorOrder {
  id                  String   @id @default(cuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id])
  vendor              String
  externalOrderNumber String?
  status              String
  rawResponse         String?
  createdAt           DateTime @default(now())
}

model ContentPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  createdAt DateTime @default(now())
}

model FinanceTransaction {
  id          String   @id @default(cuid())
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  type        String
  amountCents Int
  note        String?
  createdAt   DateTime @default(now())
}

model Checkout {
  id        String   @id @default(cuid())
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  email     String?
  cartJson  String
  status    String   @default("ABANDONED") // ABANDONED|RECOVERED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
