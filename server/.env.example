# DB path — on Railway/Render point this at a persistent volume (e.g. /data/dev.db)
DATABASE_URL="file:./dev.db"

# Directory where uploaded product images are stored.
# On Railway/Render set this to a path inside a persistent volume, e.g. /data/uploads
# Leave blank to use the default (project-local public/uploads folder)
UPLOADS_DIR=""

PORT=4000
JWT_SECRET="devsecret_change_me"   # CHANGE THIS in production — use a long random string

# CORS allowed origins (comma-separated); include your web app origin(s)
CORS_ORIGINS="http://localhost:3000"

# Initial admin credentials (used by `npm run seed`)
ADMIN_EMAIL="hello@crossroadscustomapparel.com"
ADMIN_PASSWORD="changeme123"    # change after first login

# Stripe — card / Apple Pay / Google Pay payments
STRIPE_ENABLE=true
STRIPE_SECRET_KEY=""          # sk_live_... (or sk_test_... for testing)
STRIPE_WEBHOOK_SECRET=""      # whsec_... — get this from Stripe dashboard → Webhooks

# Email (SMTP) — for order confirmations and admin alerts
SMTP_ENABLE=false
SMTP_HOST=""            # e.g. smtp.gmail.com or smtp.sendgrid.net
SMTP_PORT=587           # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=""            # SMTP login username
SMTP_PASS=""            # SMTP password or app password
SMTP_FROM="hello@crossroadscustomapparel.com"
ADMIN_NOTIFY_EMAIL="hello@crossroadscustomapparel.com"

# S&S Activewear API
SS_USER=""          # your S&S account number
SS_API_KEY=""       # your S&S API key
SS_ENABLE=false     # set true to actually post orders

# SanMar SOAP Web Services
SANMAR_CUSTOMER_NUMBER=""     # integer customer number
SANMAR_USERNAME=""            # provided by sanmar
SANMAR_PASSWORD=""            # provided by sanmar
SANMAR_WSDL_URL=""            # provided by sanmar (UAT/prod); leave blank for dry-run
SANMAR_ENABLE=false           # set true to actually submit POs

# Optional: SanMar SFTP (file-drop) path/creds if you choose that route later
SANMAR_SFTP_HOST=""
SANMAR_SFTP_USER=""
SANMAR_SFTP_PASSWORD=""
SANMAR_SFTP_ENABLE=false
